# Database
DATABASE_URL=postgresql://postgres:Mich123nBlessed@localhost:5432/video_transcoding
# postgresql://postgres:Mich123nBlessed@localhost/ragdb

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage (we'll use MinIO first)
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=videos

# JWT Secret (generate random string)
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Quality Thresholds (Advanced grade)
MIN_SOURCE_RESOLUTION=640x360
MAX_BLACK_FRAME_PERCENT=5
MAX_FROZEN_FRAME_PERCENT=2
MIN_VMAF_SCORE=70

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO