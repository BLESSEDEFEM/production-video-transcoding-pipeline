# Python cache — rebuilt automatically inside container
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist
build

# Virtual environment — container has its own Python
venv
.venv
env

# Temp files — we create these at runtime, not build time
temp_transcoding/
temp_chunks/
storage/uploads/
storage/signatures/

# Tests — not needed in production image
tests/

# Environment file — injected at runtime, not baked in
.env

# Git history — not needed in container
.git
.gitignore