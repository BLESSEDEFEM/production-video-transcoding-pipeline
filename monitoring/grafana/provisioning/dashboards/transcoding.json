{
  "title": "Video Transcoding Pipeline",
  "uid": "video-transcoding",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "title": "Jobs Completed (Total)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(transcoding_jobs_total{status='completed'})",
        "legendFormat": "Completed"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "unit": "short"
        }
      }
    },
    {
      "title": "Jobs Failed (Total)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "sum(transcoding_jobs_total{status='failed'})",
        "legendFormat": "Failed"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "unit": "short"
        }
      }
    },
    {
      "title": "Queue Depth (Current)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "transcoding_queue_depth",
        "legendFormat": "Queued"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "title": "Active Workers",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "active_workers",
        "legendFormat": "Workers"
      }],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "blue"}
        }
      }
    },
    {
      "title": "Jobs Per Minute (Rate)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "rate(transcoding_jobs_total[5m]) * 60",
        "legendFormat": "{{quality}} - {{status}}"
      }],
      "fieldConfig": {
        "defaults": {"unit": "short"}
      }
    },
    {
      "title": "Job Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(transcoding_job_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 duration - {{quality}}"
      }],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {}
}